<?xml version="1.0" encoding="utf-8" ?>

<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="FirstApp.MainPage"
    BackgroundColor="Transparent">

    <ScrollView BackgroundColor="Transparent">

        <VerticalStackLayout
            BackgroundColor="Transparent"
            Padding="20"
            Spacing="20">

            <!-- HEADER -->

            <VerticalStackLayout Spacing="2">

                <Label
                    Text="App Replay"
                    FontSize="32"
                    FontAttributes="Bold"
                    TextColor="White"/>

                <Label
                    Text="Track how your time flows across apps"
                    FontSize="14"
                    TextColor="#9CA3AF"/>

            </VerticalStackLayout>

            <!-- ACTIVE SESSION CARD -->

            <Border
                BackgroundColor="#991F2937"
                Stroke="#334155"
                StrokeThickness="1"
                Padding="16">

                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="16"/>
                </Border.StrokeShape>

                <VerticalStackLayout Spacing="10">

                    <Label
                        Text="CURRENT ACTIVITY"
                        FontSize="12"
                        TextColor="#9CA3AF"
                        FontAttributes="Bold"/>

                    <Label
                        x:Name="ActiveApp"
                        Text="App: Waiting..."
                        FontSize="24"
                        FontAttributes="Bold"
                        TextColor="White"/>

                    <Label
                        x:Name="ActiveAppLabel"
                        Text="Title: Waiting..."
                        FontSize="14"
                        TextColor="#D1D5DB"
                        LineBreakMode="TailTruncation"/>

                    <Label
                        x:Name="ActiveAppDuration"
                        Text="Duration: Waiting..."
                        FontSize="16"
                        TextColor="#60A5FA"/>

                </VerticalStackLayout>

            </Border>

            <!-- TIMELINE SECTION -->

            <VerticalStackLayout Spacing="12">

                <HorizontalStackLayout
                    HorizontalOptions="Fill"
                    Spacing="10">

                    <Label
                        Text="Timeline"
                        FontSize="22"
                        FontAttributes="Bold"
                        TextColor="White"
                        HorizontalOptions="StartAndExpand"/>

                    <Button
                        Text="-"
                        WidthRequest="45"
                        HeightRequest="40"
                        CornerRadius="12"
                        FontSize="20"
                        BackgroundColor="#374151"
                        TextColor="White"
                        Clicked="ZoomOutClicked"/>

                    <Button
                        Text="+"
                        WidthRequest="45"
                        HeightRequest="40"
                        CornerRadius="12"
                        FontSize="20"
                        BackgroundColor="#2563EB"
                        TextColor="White"
                        Clicked="ZoomInClicked"/>

                </HorizontalStackLayout>

                <Border
                    BackgroundColor="#991F2937"
                    Stroke="#334155"
                    StrokeThickness="1"
                    Padding="12">

                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="16"/>
                    </Border.StrokeShape>

                    <ScrollView Orientation="Horizontal">

                        <HorizontalStackLayout
                            x:Name="TimelineContainer"
                            Spacing="6"
                            Padding="4"/>

                    </ScrollView>

                </Border>

            </VerticalStackLayout>

            <!-- XP DASHBOARD -->

            <VerticalStackLayout Spacing="12">

                <Label
                    Text="XP Dashboard"
                    FontSize="22"
                    FontAttributes="Bold"
                    TextColor="White"/>

                <Border
                    BackgroundColor="#1F2937"
                    StrokeThickness="0"
                    Padding="16">

                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="16"/>
                    </Border.StrokeShape>

                    <VerticalStackLayout Spacing="12">

                        <Label
                            x:Name="TotalXPLabel"
                            Text="Total XP: 0"
                            FontSize="28"
                            FontAttributes="Bold"
                            TextColor="#FBBF24"/>

                        <CollectionView
                            x:Name="CategorySummaryList"
                            SelectionMode="None">

                            <CollectionView.ItemTemplate>
                                <DataTemplate>

                                    <Grid
                                        Padding="8"
                                        ColumnDefinitions="*,Auto,Auto"
                                        ColumnSpacing="14"> 

                                        <Label
                                            Grid.Column="0"
                                            Text="{Binding CategoryName}"
                                            FontSize="16"
                                            FontAttributes="Bold"
                                            TextColor="White"/>

                                        <Label
                                            Grid.Column="1"
                                            Text="{Binding FormattedTime}"
                                            FontSize="14"
                                            TextColor="#D1D5DB"/>

                                        <Label
                                            Grid.Column="2"
                                            Text="{Binding TotalXP, StringFormat='{0} XP'}"
                                            FontSize="14"
                                            FontAttributes="Bold"
                                            TextColor="#FBBF24"/>

                                    </Grid>

                                </DataTemplate>
                            </CollectionView.ItemTemplate>

                        </CollectionView>

                    </VerticalStackLayout>

                </Border>

            </VerticalStackLayout>

            <!-- DAILY SUMMARY -->

            <VerticalStackLayout Spacing="12">

                <Label
                    Text="Daily Summary"
                    FontSize="22"
                    FontAttributes="Bold"
                    TextColor="White"/>

                <Border
                    BackgroundColor="#991F2937"
                    Stroke="#334155"
                    StrokeThickness="1"
                    Padding="10">

                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="16"/>
                    </Border.StrokeShape>

                    <CollectionView
                        x:Name="SummaryList"
                        SelectionMode="None">

                        <CollectionView.ItemTemplate>

                            <DataTemplate>

                                <Grid
                                    Padding="10"
                                    ColumnDefinitions="*,Auto">

                                    <Label
                                        Grid.Column="0"
                                        Text="{Binding DisplayName}"
                                        FontSize="16"
                                        TextColor="White"
                                        FontAttributes="Bold"/>

                                    <Label
                                        Grid.Column="1"
                                        Text="{Binding FormattedTime}"
                                        FontSize="16"
                                        TextColor="#60A5FA"/>

                                </Grid>

                            </DataTemplate>

                        </CollectionView.ItemTemplate>

                    </CollectionView>

                </Border>

            </VerticalStackLayout>

            <!-- USAGE CHART -->

            <VerticalStackLayout Spacing="12">

                <Label
                    Text="Usage Chart"
                    FontSize="22"
                    FontAttributes="Bold"
                    TextColor="White"/>

                <Border
                    BackgroundColor="#991F2937"
                    Stroke="#334155"
                    StrokeThickness="1"
                    Padding="12">

                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="16"/>
                    </Border.StrokeShape>

                    <VerticalStackLayout
                        x:Name="UsageChartContainer"
                        Spacing="10"/>

                </Border>

            </VerticalStackLayout>

            <!-- SESSION HISTORY -->

            <VerticalStackLayout Spacing="12">

                <Label
                    Text="Session History"
                    FontSize="22"
                    FontAttributes="Bold"
                    TextColor="White"/>

                <Border
                    BackgroundColor="#991F2937"
                    Stroke="#334155"
                    StrokeThickness="1"
                    Padding="10">

                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="16"/>
                    </Border.StrokeShape>

                    <CollectionView
                        x:Name="SessionList"
                        SelectionMode="None">

                        <CollectionView.ItemTemplate>

                            <DataTemplate>

                                <VerticalStackLayout
                                    Padding="10"
                                    Spacing="4">

                                    <Label
                                        Text="{Binding DisplayName}"
                                        FontSize="16"
                                        FontAttributes="Bold"
                                        TextColor="White"/>

                                    <!--<Label
                                        Text="{Binding Title}"
                                        FontSize="12"
                                        TextColor="#D1D5DB"
                                        LineBreakMode="TailTruncation"/>-->

                                    <Label
                                        Text="{Binding FormattedDuration}"
                                        FontSize="12"
                                        TextColor="#60A5FA"/>

                                    <Label
                                        Text="{Binding XP, StringFormat='XP: {0}'}"
                                        FontSize="12"
                                        TextColor="#FBBF24"/>

                                </VerticalStackLayout>

                            </DataTemplate>

                        </CollectionView.ItemTemplate>

                    </CollectionView>

                </Border>

            </VerticalStackLayout>

        </VerticalStackLayout>

    </ScrollView>

</ContentPage>