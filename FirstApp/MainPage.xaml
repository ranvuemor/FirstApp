<?xml version="1.0" encoding="utf-8" ?>

<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="FirstApp.MainPage"
    BackgroundColor="#0B1020">

    <ScrollView BackgroundColor="#0B1020">

        <VerticalStackLayout
            Padding="24"
            Spacing="24">

            <!-- HEADER -->

            <Grid
                ColumnDefinitions="*,Auto"
                RowDefinitions="Auto,Auto"
                Margin="0,4,0,4">

                <Label
                    Grid.Row="0"
                    Grid.Column="0"
                    Text="App Replay"
                    FontSize="36"
                    FontAttributes="Bold"
                    TextColor="#F9FAFB"/>

                <Label
                    Grid.Row="1"
                    Grid.Column="0"
                    Text="Your personal activity timeline and XP dashboard"
                    FontSize="15"
                    TextColor="#94A3B8"/>

                <Border
                    Grid.Row="0"
                    Grid.RowSpan="2"
                    Grid.Column="1"
                    BackgroundColor="#1E293B"
                    Stroke="#334155"
                    StrokeThickness="1"
                    Padding="12"
                    VerticalOptions="Center">

                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="18"/>
                    </Border.StrokeShape>

                    <Label
                        Text="LIVE"
                        FontSize="13"
                        FontAttributes="Bold"
                        TextColor="#22C55E"/>

                </Border>

            </Grid>

            <!-- DATE FILTER -->

            <HorizontalStackLayout Spacing="8" Margin="0,10,0,10">
                <Button
                    x:Name="TodayButton"
                    Text="Today"
                    Clicked="TodayFilterClicked"
                    BackgroundColor="#2563EB"
                    TextColor="White"
                    CornerRadius="18" />

                <Button
                    x:Name="YesterdayButton"
                    Text="Yesterday"
                    Clicked="YesterdayFilterClicked"
                    BackgroundColor="#1E293B"
                    TextColor="White"
                    CornerRadius="18" />

                <Button
                    x:Name="ThisWeekButton"
                    Text="This Week"
                    Clicked="ThisWeekFilterClicked"
                    BackgroundColor="#1E293B"
                    TextColor="White"
                    CornerRadius="18" />

                <Button
                    x:Name="AllTimeButton"
                    Text="All Time"
                    Clicked="AllTimeFilterClicked"
                    BackgroundColor="#1E293B"
                    TextColor="White"
                    CornerRadius="18" />
            </HorizontalStackLayout>

            <!-- CURRENT ACTIVITY CARD -->

            <Border
                BackgroundColor="#111827"
                Stroke="#263244"
                StrokeThickness="1"
                Padding="18">

                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="22"/>
                </Border.StrokeShape>

                <Grid
                    RowDefinitions="Auto,Auto,Auto"
                    ColumnDefinitions="*,Auto"
                    RowSpacing="8">

                    <Label
                        Grid.Row="0"
                        Grid.Column="0"
                        Text="CURRENT ACTIVITY"
                        FontSize="12"
                        TextColor="#64748B"
                        FontAttributes="Bold"/>

                    <Label
                        Grid.Row="0"
                        Grid.Column="1"
                        x:Name="ActiveAppDuration"
                        Text="Duration: Waiting..."
                        FontSize="15"
                        FontAttributes="Bold"
                        TextColor="#38BDF8"
                        HorizontalTextAlignment="End"/>

                    <Label
                        Grid.Row="1"
                        Grid.Column="0"
                        Grid.ColumnSpan="2"
                        x:Name="ActiveApp"
                        Text="App: Waiting..."
                        FontSize="30"
                        FontAttributes="Bold"
                        TextColor="#F8FAFC"/>

                    <Label
                        Grid.Row="2"
                        Grid.Column="0"
                        Grid.ColumnSpan="2"
                        x:Name="ActiveAppLabel"
                        Text="Title: Waiting..."
                        FontSize="14"
                        TextColor="#CBD5E1"
                        LineBreakMode="TailTruncation"/>

                </Grid>

            </Border>

            <!-- DASHBOARD GRID -->

            <Grid
                ColumnDefinitions="*,*"
                RowDefinitions="Auto,Auto,Auto,Auto"
                ColumnSpacing="16"
                RowSpacing="16">

                <!-- XP DASHBOARD -->

                <Border
                    Grid.Row="0"
                    Grid.Column="0"
                    BackgroundColor="#151B2E"
                    Stroke="#334155"
                    StrokeThickness="1"
                    Padding="16">

                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="24"/>
                    </Border.StrokeShape>

                    <VerticalStackLayout Spacing="12">

                        <Grid ColumnDefinitions="*,Auto">

                            <VerticalStackLayout Spacing="2">

                                <Label
                                    Text="XP Dashboard"
                                    FontSize="20"
                                    FontAttributes="Bold"
                                    TextColor="#F8FAFC"/>

                                <Label
                                    x:Name="XpDashboardSubtitle"
                                    Text="Today's progress"
                                    FontSize="12"
                                    TextColor="#94A3B8"/>

                            </VerticalStackLayout>

                            <Label
                                Grid.Column="1"
                                x:Name="TotalXPLabel"
                                Text="Total XP: 0"
                                FontSize="15"
                                FontAttributes="Bold"
                                TextColor="#FBBF24"
                                VerticalOptions="Center"/>

                        </Grid>

                        <Border
                            BackgroundColor="#0F172A"
                            Stroke="#1E293B"
                            StrokeThickness="1"
                            Padding="12">

                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="18"/>
                            </Border.StrokeShape>

                            <VerticalStackLayout Spacing="8">

                                <Grid ColumnDefinitions="*,Auto">

                                    <Label
                                        x:Name="LevelLabel"
                                        Text="Level 1"
                                        FontSize="26"
                                        FontAttributes="Bold"
                                        TextColor="White"/>

                                    <Label
                                        Grid.Column="1"
                                        x:Name="LevelProgressLabel"
                                        Text="0 / 100 XP"
                                        FontSize="13"
                                        TextColor="#CBD5E1"
                                        VerticalOptions="Center"/>

                                </Grid>

                                <ProgressBar
                                    x:Name="LevelProgressBar"
                                    Progress="0"
                                    HeightRequest="8"
                                    ProgressColor="#FBBF24"
                                    BackgroundColor="#334155"/>

                            </VerticalStackLayout>

                        </Border>

                        <CollectionView
                            x:Name="CategorySummaryList"
                            SelectionMode="None"
                            HeightRequest="170">

                            <CollectionView.ItemTemplate>
                                <DataTemplate>

                                    <Border
                                        BackgroundColor="#0F172A"
                                        Stroke="#1E293B"
                                        StrokeThickness="1"
                                        Padding="10"
                                        Margin="0,3">

                                        <Border.StrokeShape>
                                            <RoundRectangle CornerRadius="14"/>
                                        </Border.StrokeShape>

                                        <Grid
                                            ColumnDefinitions="*,Auto,Auto"
                                            ColumnSpacing="10">

                                            <Label
                                                Grid.Column="0"
                                                Text="{Binding CategoryName}"
                                                FontSize="14"
                                                FontAttributes="Bold"
                                                TextColor="#F8FAFC"
                                                VerticalOptions="Center"/>

                                            <Label
                                                Grid.Column="1"
                                                Text="{Binding FormattedTime}"
                                                FontSize="12"
                                                TextColor="#CBD5E1"
                                                VerticalOptions="Center"/>

                                            <Label
                                                Grid.Column="2"
                                                Text="{Binding TotalXP, StringFormat='{0} XP'}"
                                                FontSize="12"
                                                FontAttributes="Bold"
                                                TextColor="#FBBF24"
                                                VerticalOptions="Center"/>

                                        </Grid>

                                    </Border>

                                </DataTemplate>
                            </CollectionView.ItemTemplate>

                        </CollectionView>

                    </VerticalStackLayout>

                </Border>

                <!-- ACTIVITY SUMMARY -->

                <Border
                    Grid.Row="0"
                    Grid.Column="1"
                    BackgroundColor="#111827"
                    Stroke="#263244"
                    StrokeThickness="1"
                    Padding="16">

                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="24"/>
                    </Border.StrokeShape>

                    <VerticalStackLayout Spacing="12">

                        <Grid ColumnDefinitions="*,Auto">

                            <VerticalStackLayout Spacing="2">

                                <Label
                                    Text="Activity Summary"
                                    FontSize="20"
                                    FontAttributes="Bold"
                                    TextColor="#F8FAFC"/>

                                <Label
                                    Text="Time by app"
                                    FontSize="12"
                                    TextColor="#94A3B8"/>

                            </VerticalStackLayout>

                            <Label
                                x:Name="ActivitySummaryPreview"
                                Grid.Column="1"
                                Text="0s total"
                                FontSize="12"
                                TextColor="#38BDF8"
                                VerticalOptions="Center"/>

                        </Grid>

                        <CollectionView
                            x:Name="SummaryList"
                            SelectionMode="None"
                            HeightRequest="210">

                            <CollectionView.ItemTemplate>
                                <DataTemplate>

                                    <Grid
                                        Padding="7"
                                        ColumnDefinitions="*,Auto">

                                        <Label
                                            Grid.Column="0"
                                            Text="{Binding DisplayName}"
                                            FontSize="14"
                                            TextColor="#F8FAFC"
                                            FontAttributes="Bold"/>

                                        <Label
                                            Grid.Column="1"
                                            Text="{Binding FormattedTime}"
                                            FontSize="14"
                                            TextColor="#38BDF8"/>

                                    </Grid>

                                </DataTemplate>
                            </CollectionView.ItemTemplate>

                        </CollectionView>

                    </VerticalStackLayout>

                </Border>

                <!-- TIMELINE SECTION -->

                <Border
                    Grid.Row="1"
                    Grid.Column="0"
                    Grid.ColumnSpan="2"
                    BackgroundColor="#111827"
                    Stroke="#263244"
                    StrokeThickness="1"
                    Padding="16">

                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="24"/>
                    </Border.StrokeShape>

                    <VerticalStackLayout Spacing="12">

                        <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="10">

                            <VerticalStackLayout Spacing="2">

                                <Label
                                    Text="Timeline"
                                    FontSize="20"
                                    FontAttributes="Bold"
                                    TextColor="#F8FAFC"/>

                                <Label
                                    Text="Zoom and scroll through your activity flow"
                                    FontSize="12"
                                    TextColor="#94A3B8"/>

                            </VerticalStackLayout>

                            <Button
                                Grid.Column="1"
                                Text="−"
                                WidthRequest="40"
                                HeightRequest="36"
                                CornerRadius="12"
                                FontSize="20"
                                BackgroundColor="#1E293B"
                                TextColor="White"
                                Clicked="ZoomOutClicked"/>

                            <Button
                                Grid.Column="2"
                                Text="+"
                                WidthRequest="40"
                                HeightRequest="36"
                                CornerRadius="12"
                                FontSize="20"
                                BackgroundColor="#2563EB"
                                TextColor="White"
                                Clicked="ZoomInClicked"/>

                        </Grid>

                        <Border
                            BackgroundColor="#0B1120"
                            Stroke="#1E293B"
                            StrokeThickness="1"
                            Padding="10">

                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="18"/>
                            </Border.StrokeShape>

                            <ScrollView Orientation="Horizontal">

                                <HorizontalStackLayout
                                    x:Name="TimelineContainer"
                                    Spacing="7"
                                    Padding="4"/>

                            </ScrollView>

                        </Border>

                    </VerticalStackLayout>

                </Border>

                <!-- HOURLY HEATMAP -->

                <Border
                    Grid.Row="2"
                    Grid.Column="0"
                    Grid.ColumnSpan="2"
                    BackgroundColor="#111827"
                    Stroke="#263244"
                    StrokeThickness="1"
                    Padding="16">

                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="24"/>
                    </Border.StrokeShape>

                    <VerticalStackLayout Spacing="12">

                        <Grid ColumnDefinitions="*,Auto">

                            <VerticalStackLayout Spacing="2">

                                <Label
                                    Text="Hourly Activity"
                                    FontSize="20"
                                    FontAttributes="Bold"
                                    TextColor="#F8FAFC"/>

                                <Label
                                    Text="Average activity by hour for the selected range"
                                    FontSize="12"
                                    TextColor="#94A3B8"/>

                            </VerticalStackLayout>

                            <Label
                                x:Name="HeatmapPreview"
                                Grid.Column="1"
                                Text="0h tracked"
                                FontSize="12"
                                TextColor="#38BDF8"
                                VerticalOptions="Center"/>

                        </Grid>

                        <ScrollView Orientation="Horizontal">

                            <HorizontalStackLayout
                                x:Name="HourlyHeatmapContainer"
                                Spacing="8"
                                Padding="2"/>

                        </ScrollView>

                    </VerticalStackLayout>

                </Border>

                <!-- ACTIVITY DETAILS -->

                <Border
                    Grid.Row="3"
                    Grid.Column="0"
                    Grid.ColumnSpan="2"
                    BackgroundColor="#111827"
                    Stroke="#263244"
                    StrokeThickness="1"
                    Padding="16">

                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="24"/>
                    </Border.StrokeShape>

                    <VerticalStackLayout Spacing="14">

                        <Grid ColumnDefinitions="*,Auto,Auto">
                            <Grid.GestureRecognizers>
                                <TapGestureRecognizer Tapped="DetailsHeaderTapped"/>
                            </Grid.GestureRecognizers>

                            <VerticalStackLayout Grid.Column="0" Spacing="2">

                                <Label
                                    Text="Details"
                                    FontSize="20"
                                    FontAttributes="Bold"
                                    TextColor="#F8FAFC"/>

                                <Label
                                    x:Name="DetailsSubtitle"
                                    Text="Usage chart and session history for today"
                                    FontSize="12"
                                    TextColor="#94A3B8"/>

                            </VerticalStackLayout>

                            <Label
                                x:Name="DetailsPreview"
                                Grid.Column="1"
                                Text="No data"
                                FontSize="12"
                                TextColor="#38BDF8"
                                VerticalOptions="Center"
                                Margin="0,0,10,0"/>

                            <Label
                                x:Name="DetailsChevron"
                                Grid.Column="2"
                                Text="⌄"
                                FontSize="22"
                                FontAttributes="Bold"
                                TextColor="#94A3B8"
                                VerticalOptions="Center"/>

                        </Grid>

                        <Grid
                            x:Name="DetailsContent"
                            IsVisible="False"
                            ColumnDefinitions="*,*"
                            ColumnSpacing="16">

                            <!-- USAGE CHART SIDE -->

                            <VerticalStackLayout
                                Grid.Column="0"
                                Spacing="10">

                                <Label
                                    Text="Usage Chart"
                                    FontSize="16"
                                    FontAttributes="Bold"
                                    TextColor="#F8FAFC"/>

                                <VerticalStackLayout
                                    x:Name="UsageChartContainer"
                                    Spacing="8"/>

                            </VerticalStackLayout>

                            <!-- SESSION HISTORY SIDE -->

                            <VerticalStackLayout
                                Grid.Column="1"
                                Spacing="10">

                                <Label
                                    Text="Session History"
                                    FontSize="16"
                                    FontAttributes="Bold"
                                    TextColor="#F8FAFC"/>

                                <CollectionView
                                    x:Name="SessionList"
                                    SelectionMode="None"
                                    HeightRequest="230">

                                    <CollectionView.ItemTemplate>
                                        <DataTemplate>

                                            <Border
                                                BackgroundColor="#0F172A"
                                                Stroke="#1E293B"
                                                StrokeThickness="1"
                                                Padding="10"
                                                Margin="0,4">

                                                <Border.StrokeShape>
                                                    <RoundRectangle CornerRadius="14"/>
                                                </Border.StrokeShape>

                                                <Grid
                                                    ColumnDefinitions="*,Auto"
                                                    RowDefinitions="Auto,Auto"
                                                    RowSpacing="3">

                                                    <Label
                                                        Grid.Row="0"
                                                        Grid.Column="0"
                                                        Text="{Binding DisplayName}"
                                                        FontSize="14"
                                                        FontAttributes="Bold"
                                                        TextColor="#F8FAFC"/>

                                                    <Label
                                                        Grid.Row="0"
                                                        Grid.Column="1"
                                                        Text="{Binding XP, StringFormat='{0} XP'}"
                                                        FontSize="12"
                                                        FontAttributes="Bold"
                                                        TextColor="#FBBF24"/>

                                                    <Label
                                                        Grid.Row="1"
                                                        Grid.Column="0"
                                                        Text="{Binding FormattedDuration}"
                                                        FontSize="12"
                                                        TextColor="#38BDF8"/>

                                                </Grid>

                                            </Border>

                                        </DataTemplate>
                                    </CollectionView.ItemTemplate>

                                </CollectionView>

                            </VerticalStackLayout>

                        </Grid>

                    </VerticalStackLayout>

                </Border>

            </Grid>

        </VerticalStackLayout>

    </ScrollView>

</ContentPage>